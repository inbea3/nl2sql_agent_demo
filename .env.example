## 大模型（LLM）
NL2SQL_API_KEY=replace_me  # 例如：sk-xxx
NL2SQL_BASE_URL=replace_me  # 例如：https://dashscope.aliyuncs.com/compatible-mode/v1
NL2SQL_MODEL_NAME=replace_me  # 例如：qwen3-coder-480b-a35b-instruct

## Postgres / Neon
NL2SQL_DB_HOST=replace_me  # 例如：ep-xxx.ap-southeast-1.aws.neon.tech
NL2SQL_DB_DATABASE=replace_me
NL2SQL_DB_USER=replace_me
NL2SQL_DB_PASSWORD=replace_me  # 例如：npg_xxx
NL2SQL_DB_PORT=replace_me
NL2SQL_DB_SSLMODE=require

## 可选配置
NL2SQL_SCHEMA_VALIDATE=1
NL2SQL_SCHEMA_AUTO_REFRESH=0
# 本地 schema 缓存文件路径（默认：项目根目录 database_schema.json；可填绝对路径）
# NL2SQL_SCHEMA_JSON_PATH=

